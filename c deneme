int cati(){
    int h = 5; // çatı yüksekliği — değiştirerek boyutu ayarlayın

    // üçgen gövdesi
    for (int i = 0; i < h; i++) {
        // sol boşluklar
        for (int s = 0; s < h - i - 1; s++) printf(" ");
        // sol eğik çizgi
        printf("/");
        // iç boşluklar (i==0 için 0)
        for (int k = 0; k < 2 * i; k++) printf(" ");
        // sağ eğik çizgi (backslash için "\\" kullanılır)
        printf("\\\n");
    }

    // taban (alt çizgi)
    printf("/");
    for (int k = 0; k < 2 * h - 1; k++) printf("_");
    printf("\\\n");

    return 0;
}